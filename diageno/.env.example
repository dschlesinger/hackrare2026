# ── Runtime ──────────────────────────────────────────
POSTGRES_DSN=postgresql://diageno:diageno@localhost:5432/diageno
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Data Paths (local / PVC mount) ──────────────────
DATA_DIR=/data
BRONZE_DIR=/data/bronze
SILVER_DIR=/data/silver
GOLD_DIR=/data/gold
ARTIFACTS_DIR=/data/model_artifacts

# ── Model / Embedding ───────────────────────────────
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Cache TTL (seconds) ─────────────────────────────
CACHE_TTL_HPO_LOOKUP=3600
CACHE_TTL_DISEASE_TOP=300
CACHE_TTL_RECOMMEND=300
CACHE_TTL_EVIDENCE=1800

# ── API ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# ── UI ───────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
